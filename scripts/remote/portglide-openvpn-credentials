#!/usr/bin/env bash
set -euo pipefail

INSTANCE="${1:-}"
if [[ ! "${INSTANCE}" =~ ^[A-Za-z0-9_.-]+$ ]]; then
    echo "Invalid OpenVPN instance" >&2
    exit 2
fi

CONFIG_FILE="/etc/openvpn/client/${INSTANCE}.conf"
AUTH_FILE="/etc/openvpn/client/${INSTANCE}.auth"
UNIT="openvpn-client@${INSTANCE}"

if [ ! -f "${CONFIG_FILE}" ]; then
    echo "OpenVPN config not found: ${CONFIG_FILE}" >&2
    exit 3
fi

IFS= read -r VPN_USERNAME
IFS= read -r VPN_PASSWORD

if [ -z "${VPN_USERNAME}" ] || [ -z "${VPN_PASSWORD}" ]; then
    echo "Username and password are required" >&2
    exit 4
fi
if [ "${#VPN_USERNAME}" -gt 256 ] || [ "${#VPN_PASSWORD}" -gt 1024 ]; then
    echo "Credential value is too long" >&2
    exit 5
fi

umask 077
TEMP_FILE="$(mktemp "/etc/openvpn/client/.${INSTANCE}.auth.XXXXXX")"
trap 'rm -f "${TEMP_FILE}"' EXIT

printf '%s\n%s\n' "${VPN_USERNAME}" "${VPN_PASSWORD}" > "${TEMP_FILE}"
chown root:root "${TEMP_FILE}"
chmod 600 "${TEMP_FILE}"
mv -f "${TEMP_FILE}" "${AUTH_FILE}"
trap - EXIT

systemctl restart "${UNIT}"
for _ in $(seq 1 20); do
    systemctl is-active --quiet "${UNIT}" && exit 0
    systemctl is-failed --quiet "${UNIT}" && break
    sleep 1
done

echo "OpenVPN failed to become active" >&2
exit 6

